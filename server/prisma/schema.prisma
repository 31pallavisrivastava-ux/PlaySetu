generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  OWNER
  ADMIN
}

enum FacilityStatus {
  PENDING
  ACTIVE
  INACTIVE
}

enum CourtStatus {
  ACTIVE
  MAINTENANCE
  INACTIVE
}

enum SlotAvailability {
  AVAILABLE
  LOCKED
  BOOKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum PaymentProvider {
  RAZORPAY
  STRIPE
  MOCK
}

model User {
  id               String    @id @default(uuid())
  name             String
  email            String    @unique
  phone            String?   @unique
  passwordHash     String    @map("password_hash")
  role             UserRole  @default(USER)
  skillLevel       String?   @map("skill_level")
  preferredSports  Json?     @map("preferred_sports")
  location         String?
  latitude         Float?
  longitude        Float?
  refreshToken     String?   @map("refresh_token") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  facilities   Facility[]    @relation("FacilityOwner")
  bookings     Booking[]
  reviews      Review[]
  chatMessages ChatMessage[]

  @@map("users")
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      String
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_messages")
}

model Facility {
  id           String         @id @default(uuid())
  name         String
  description  String?        @db.Text
  sportType    String         @map("sport_type")
  address      String
  area         String?
  latitude     Float
  longitude    Float
  ownerId      String         @map("owner_id")
  rating       Float          @default(0)
  openingTime  String         @map("opening_time")
  closingTime  String         @map("closing_time")
  skillLevels  Json?          @map("skill_levels")
  status       FacilityStatus @default(PENDING)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  owner   User     @relation("FacilityOwner", fields: [ownerId], references: [id])
  courts  Court[]
  reviews Review[]

  @@index([sportType, area])
  @@index([latitude, longitude])
  @@map("facilities")
}

model Court {
  id           String      @id @default(uuid())
  facilityId   String      @map("facility_id")
  name         String
  type         String
  pricePerHour Decimal     @map("price_per_hour") @db.Decimal(10, 2)
  maxPlayers   Int         @default(10) @map("max_players")
  status       CourtStatus @default(ACTIVE)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  slots    Slot[]

  @@map("courts")
}

model Slot {
  id           String           @id @default(uuid())
  courtId      String           @map("court_id")
  date         DateTime         @db.Date
  startTime    String           @map("start_time")
  endTime      String           @map("end_time")
  availability SlotAvailability @default(AVAILABLE)
  lockExpiresAt DateTime?       @map("lock_expires_at")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  court    Court     @relation(fields: [courtId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@unique([courtId, date, startTime])
  @@index([date, availability])
  @@map("slots")
}

model Booking {
  id            String        @id @default(uuid())
  userId        String        @map("user_id")
  slotId        String        @map("slot_id")
  bookingStatus BookingStatus @default(PENDING) @map("booking_status")
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  user    User     @relation(fields: [userId], references: [id])
  slot    Slot     @relation(fields: [slotId], references: [id])
  payment Payment?

  @@index([userId])
  @@map("bookings")
}

model Payment {
  id            String          @id @default(uuid())
  bookingId     String          @unique @map("booking_id")
  transactionId String?         @map("transaction_id")
  provider      PaymentProvider @default(MOCK)
  status        PaymentStatus   @default(PENDING)
  amount        Decimal         @db.Decimal(10, 2)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Review {
  id         String   @id @default(uuid())
  facilityId String   @map("facility_id")
  userId     String   @map("user_id")
  rating     Int
  review     String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  facility Facility @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([facilityId, userId])
  @@map("reviews")
}
